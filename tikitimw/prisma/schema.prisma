generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum RoleType {
  SUPER_ADMIN
  ADMIN
  ORGANIZER
  STAFF
  SCANNER
}